{
  "name": "FunWithMermaid",
  "displayName": "FunWithMermaid",
  "description": "Preview and edit Mermaid diagrams natively",
  "version": "1.0.1",
  "publisher": "WoHoooPublications",
  "repository": {
    "type": "git",
    "url": "https://github.com/KushagarGoel/mermaid-editor-vscode"
  },
  "engines": {
    "vscode": "^1.108.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages"
  ],
  "activationEvents": [
    "onCommand:FunWithMermaid.preview"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mermaid",
        "extensions": [
          ".mmd",
          ".mermaid"
        ],
        "aliases": [
          "Mermaid",
          "mermaid"
        ]
      }
    ],
    "commands": [
      {
        "command": "FunWithMermaid.preview",
        "title": "FunWithMermaid: Open Preview",
        "category": "Mermaid",
        "icon": "$(preview)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.108.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "mermaid": "^11.12.3"
  }
}